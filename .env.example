# ─── Database ────────────────────────────────────────────────────────────────
# SQLite for local development (no setup required)
DATABASE_URL="file:./dev.db"

# ─── GitHub OAuth App ────────────────────────────────────────────────────────
# Create one at: https://github.com/settings/developers
# Set "Authorization callback URL" to: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# ─── GitHub Personal Access Token (for Issue Sync) ───────────────────────────
# Generate at: https://github.com/settings/tokens
# Required scopes: public_repo, read:user
# Leave blank to use the built-in simulation mode
GITHUB_PERSONAL_ACCESS_TOKEN=""

# ─── Session Security ─────────────────────────────────────────────────────────
# Generate a strong random secret for JWT signing
JWT_SECRET="replace-with-a-long-random-secret-string"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Developer Mode ───────────────────────────────────────────────────────────
# Set to "true" to bypass GitHub OAuth and log in with a mock developer account
# Useful for local development without a GitHub OAuth App
NEXT_PUBLIC_DEV_MODE="true"
